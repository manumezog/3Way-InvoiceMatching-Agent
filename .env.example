# =============================================================================
# FastPay AI — Environment Variables
# Copy this file to .env.local and fill in your values.
# .env.local is gitignored and will never be committed.
# =============================================================================

# -----------------------------------------------------------------------------
# Database
# Default: local SQLite at ./data/fastpay.db (used in development)
# Production: set to your Neon Postgres connection string
# -----------------------------------------------------------------------------
# DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# -----------------------------------------------------------------------------
# AI — Google Gemini (required from Phase 3 onward)
# Get your key at: https://aistudio.google.com/apikey
# -----------------------------------------------------------------------------
# GEMINI_API_KEY=your-gemini-api-key-here

# -----------------------------------------------------------------------------
# AI — OpenRouter (optional fallback)
# Get your key at: https://openrouter.ai/keys
# -----------------------------------------------------------------------------
# OPENROUTER_API_KEY=your-openrouter-api-key-here

# -----------------------------------------------------------------------------
# Observability — Langfuse (required from Phase 4 onward)
# Sign up at: https://langfuse.com (free tier)
# -----------------------------------------------------------------------------
# LANGFUSE_PUBLIC_KEY=pk-lf-...
# LANGFUSE_SECRET_KEY=sk-lf-...
# LANGFUSE_BASE_URL=https://cloud.langfuse.com

# -----------------------------------------------------------------------------
# Rate Limiting — Upstash Redis (required from Phase 8 onward)
# Sign up at: https://upstash.com (free tier)
# -----------------------------------------------------------------------------
# UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
# UPSTASH_REDIS_REST_TOKEN=your-token-here
