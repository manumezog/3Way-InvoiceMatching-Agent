# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# local database (but keep scenarios.json which is source-of-truth)
/data/*.db
/data/*.sqlite
/data/*.db-shm
/data/*.db-wal

# generated assets (reproduced by seed script)
/public/invoices/*.pdf
/public/invoices/*.png
/public/invoices/byoi-*
# thumbnails are committed so Vercel can serve them (static scenario JPGs only, ~150KB total)
/public/thumbnails/byoi-*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
